# Docker Environment Variables
# Copy this file to .env and fill in your values

# Groq API Key (required for chat / LLM)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace embeddings (local, no API key)
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# JWT Secret (generate a secure random string for production)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (these should match docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/policy_assistant

# Optional: Google Drive Integration
# Place credentials.json in backend/ directory
GOOGLE_DRIVE_CREDENTIALS_PATH=./backend/credentials.json
